#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OUT="$ROOT/.out"

usage() {
  cat <<'USAGE'
Usage: bash scripts/dev <command> [args]

Commands:
  doctor                         Check Mac/Android development environment
  plan                           Print the staged technical gates
  lock-check                     Validate lock files without building
  candidates-check [--network]   Validate candidate SHAs; optionally fetch official remotes
  core-test                      Build and test the platform-independent C++ input core
  probe-analyze <events.jsonl>   Validate and summarize an input probe log
  target-preflight [args]        Check Android sysroot pkg-config dependencies
  repo-check                     Check that generated/binary paths are not tracked
  test                           Run all host-side pre-engineering checks
USAGE
}

cmd="${1:-}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$cmd" in
  doctor)
    exec bash "$ROOT/scripts/doctor-macos.sh"
    ;;
  plan)
    cat "$ROOT/docs/stage-gates.md"
    ;;
  lock-check)
    python3 - "$ROOT" <<'PY'
import pathlib, sys, tomllib
root = pathlib.Path(sys.argv[1])
with (root / "sources.lock.toml").open("rb") as f:
    data = tomllib.load(f)
assert data["format_version"] == 1
assert data["android"]["abi"] == "arm64-v8a"
print(f"lock status: {data['status']}")
if data["status"] == "validated":
    for name in ("inkscape", "gtk", "pixiewood"):
        assert data[name]["commit"], f"missing validated commit: {name}"
PY
    ;;
  candidates-check)
    exec python3 "$ROOT/scripts/verify-source-candidates.py" "$@"
    ;;
  core-test)
    build="$OUT/core-tablet-input"
    cmake -S "$ROOT/core/tablet-input" -B "$build" -G Ninja \
      -DCMAKE_BUILD_TYPE=RelWithDebInfo \
      -DTABLET_INPUT_BUILD_TESTS=ON
    cmake --build "$build"
    ctest --test-dir "$build" --output-on-failure
    ;;
  probe-analyze)
    if [[ $# -ne 1 ]]; then
      echo "probe-analyze requires one JSONL path" >&2
      exit 2
    fi
    exec python3 "$ROOT/tools/analyze_input_probe.py" "$1" --strict
    ;;
  target-preflight)
    exec python3 "$ROOT/scripts/check-inkscape-cross-preconditions.py" "$@"
    ;;
  repo-check)
    bad="$(git -C "$ROOT" ls-files | grep -E '(^|/)(\.work|\.out|\.cache|build|_build|\.pixiewood)(/|$)|\.(apk|aab|so|a|dylib)$' || true)"
    if [[ -n "$bad" ]]; then
      echo "Generated or binary files are tracked:" >&2
      echo "$bad" >&2
      exit 1
    fi
    echo "repository tracking policy: OK"
    ;;
  test)
    bash "$ROOT/scripts/dev" lock-check
    bash "$ROOT/scripts/dev" candidates-check
    python3 -m unittest discover -s "$ROOT/tools/tests" -p 'test_*.py' -v
    bash "$ROOT/scripts/dev" core-test
    bash "$ROOT/scripts/dev" repo-check
    ;;
  *)
    usage
    exit 2
    ;;
esac
